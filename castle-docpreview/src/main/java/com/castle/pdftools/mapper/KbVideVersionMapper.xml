<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.castle.pdftools.mapper.KbVideVersionMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="kbVideVersionMap" type="com.castle.pdftools.entity.KbVideVersionEntity">
        <result column="id" property="id"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_name" property="fileName"/>
        <result column="url" property="url"/>
        <result column="create_time" property="createTime"/>
        <result column="create_user" property="createUser"/>
        <result column="update_user" property="updateUser"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="b_id" property="bId"/>
        <result column="f_id" property="fId"/>
        <result column="access_path" property="AccessPath"/>
        <result column="file_size" property="fileSize"/>
        <result column="type" property="type"/>
        <result column="ststus" property="status"/>
    </resultMap>
    <select id="selectByBid" resultMap="kbVideVersionMap"
            parameterType="java.lang.String">
        select * from kb_vide_version where b_id=#{bid} and status !=1
    </select>

    <select id="selectByStatus"  resultMap="kbVideVersionMap">
        select * from kb_vide_version where status !=#{num}
    </select>
</mapper>
