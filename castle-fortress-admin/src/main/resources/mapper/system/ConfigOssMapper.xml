<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.castle.fortress.admin.system.mapper.ConfigOssMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="configOssMap" type="com.castle.fortress.admin.system.entity.ConfigOssEntity">
        <result column="id" property="id"/>
        <result column="ft_code" property="ftCode" />
        <result column="platform" property="platform"/>
        <result column="pt_config" property="ptConfig"/>
        <result column="remark" property="remark" />
        <result column="status" property="status"/>
        <result column="create_user" property="createUser"/>
        <result column="create_time" property="createTime"/>
        <result column="update_user" property="updateUser"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>
    <update id="updateStatusNo">
        update castle_config_oss set status = 2
    </update>
    <select id="selectStatusYes" resultMap="configOssMap">
        select * from castle_config_oss where status = 1
    </select>

</mapper>
