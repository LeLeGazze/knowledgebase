<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.castle.fortress.admin.system.mapper.SysRoleMenuMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="sysRoleMenuMap" type="com.castle.fortress.admin.system.entity.SysRoleMenu">
        <result column="id" property="id"/>
        <result column="menu_id" property="menuId"/>
        <result column="role_id" property="roleId"/>
    </resultMap>
    <delete id="delByRoleId">
        delete from castle_sys_role_menu where role_id=#{roleId}
    </delete>
    <delete id="delByMenuId">
        delete from castle_sys_role_menu where menu_id=#{menuId}
    </delete>
    <insert id="menuAuthSave" parameterType="java.util.List">
        INSERT INTO castle_sys_role_menu (id,role_id, menu_id)
        VALUES <foreach collection="list" item="item" index="index"
                        separator=",">
        ( #{item.id},#{item.roleId}, #{item.menuId})
    </foreach>
    </insert>
</mapper>
