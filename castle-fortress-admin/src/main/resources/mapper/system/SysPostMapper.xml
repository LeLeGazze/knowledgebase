<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.castle.fortress.admin.system.mapper.SysPostMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="sysPostMap" type="com.castle.fortress.admin.system.entity.SysPostEntity">
        <result column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="remark" property="remark"/>
        <result column="parent_id" property="parentId"/>
        <result column="dept_id" property="deptId"/>
        <result column="data_auth_type" property="dataAuthType"/>
        <result column="status" property="status"/>
        <result column="create_user" property="createUser"/>
        <result column="create_time" property="createTime"/>
        <result column="update_user" property="updateUser"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>
    <resultMap id="sysPostExtendsMap" extends="sysPostMap" type="com.castle.fortress.admin.system.entity.SysPostEntity">
        <result column="create_user_name" property="createUserName" />
    </resultMap>
    <select id="leadersPost" resultMap="sysPostMap">
        select * from castle_sys_post
        where data_auth_type = 1
        and is_deleted=2
        and (
        <if test="deptId!=null and deptId !=0 ">
            dept_id = #{deptId}
        </if>
        <if test='deptParents!=null and deptParents !=""'>
          or find_in_set(dept_id,#{deptParents})
        </if>
        )
    </select>

</mapper>
