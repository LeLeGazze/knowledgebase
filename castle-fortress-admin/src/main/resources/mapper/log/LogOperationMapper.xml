<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.castle.fortress.admin.log.mapper.LogOperationMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="logOperationMap" type="com.castle.fortress.admin.log.entity.LogOperationEntity">
        <result column="id" property="id"/>
        <result column="invoke_url" property="invokeUrl"/>
        <result column="invoke_params" property="invokeParams"/>
        <result column="class_name" property="className"/>
        <result column="method_name" property="methodName"/>
        <result column="invoke_status" property="invokeStatus"/>
        <result column="invoke_user_id" property="invokeUserId"/>
        <result column="invoke_user_name" property="invokeUserName"/>
        <result column="invoke_time" property="invokeTime"/>
        <result column="result_data" property="resultData"/>
        <result column="elapsed_time" property="elapsedTime"/>
        <result column="create_time" property="createTime"/>
        <result column="oper_location" property="operLocation"/>
        <result column="oper_type" property="operType"/>
    </resultMap>

    <delete id="deleteByTime">
        DELETE FROM castle_log_operation WHERE create_time &lt; CURRENT_TIMESTAMP - INTERVAL ${days} DAY
    </delete>

</mapper>
